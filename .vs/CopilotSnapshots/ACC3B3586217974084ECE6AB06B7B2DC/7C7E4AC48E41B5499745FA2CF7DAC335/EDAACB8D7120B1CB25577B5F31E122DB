using System;
using System.Data;
using System.Data.SqlClient;
using System.Web.Mvc;
using CRMCiclo.Context;

namespace CRMCiclo.Controllers
{
    public class PanelAdViewController : Controller
    {
        public ActionResult Index()
        {
            if (Session["UsuarioId"] == null)
                return RedirectToAction("Index", "AccesoAdministradorView");

            try
            {
                using (var db = new NombreContext())
                using (var cmd = db.CreateCommand("sp_ObtenerResumenPanel"))
                {
                    db.Connection.Open();
                    using (var reader = cmd.ExecuteReader())
                    {
                        if (reader.Read())
                        {
                            ViewBag.TotalProspectos = reader["TotalProspectos"] != DBNull.Value ? Convert.ToInt32(reader["TotalProspectos"]) : 0;
                            ViewBag.ProspectosNuevos = reader["ProspectosNuevos"] != DBNull.Value ? Convert.ToInt32(reader["ProspectosNuevos"]) : 0;
                            ViewBag.ProspectosEnSeguimiento = reader["ProspectosEnSeguimiento"] != DBNull.Value ? Convert.ToInt32(reader["ProspectosEnSeguimiento"]) : 0;
                            ViewBag.ProspectosCerrados = reader["ProspectosCerrados"] != DBNull.Value ? Convert.ToInt32(reader["ProspectosCerrados"]) : 0;
                        }
                    }
                }
            }
            catch
            {
                ViewBag.TotalProspectos = 0;
                ViewBag.ProspectosNuevos = 0;
                ViewBag.ProspectosEnSeguimiento = 0;
                ViewBag.ProspectosCerrados = 0;
            }

            return View();
        }

        public ActionResult TarjetasResumen()
        {
            if (Session["UsuarioId"] == null)
                return new HttpStatusCodeResult(401);

            return PartialView("_TarjetasResumen");
        }
    }
}
