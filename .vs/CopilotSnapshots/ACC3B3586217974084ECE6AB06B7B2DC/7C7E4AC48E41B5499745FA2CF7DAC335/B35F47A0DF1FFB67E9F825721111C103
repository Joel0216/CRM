@using CRMCiclo.Models
@{
    var lista = ViewBag.Prospectos as List<ProspectoModel> ?? new List<ProspectoModel>();
}

<table id="tablaProspectos" class="table">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Empresa</th>
            <th>TelÃ©fono</th>
            <th>Email</th>
            <th>Origen</th>
            <th>Estatus</th>
            <th>Fecha</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var p in lista)
        {
            <tr>
                <td>@p.NombreCompleto</td>
                <td>@p.Empresa</td>
                <td>@p.Telefono</td>
                <td>@p.Email</td>
                <td>@p.Origen</td>
                <td>
                    @{
                        var badgeClass = "badge-status ";
                        var estatusLower = (p.Estatus ?? "").ToLower();
                        if (estatusLower == "nuevo") { badgeClass += "badge-nuevo"; }
                        else if (estatusLower == "en seguimiento") { badgeClass += "badge-seguimiento"; }
                        else if (estatusLower == "cotizado") { badgeClass += "badge-cotizado"; }
                        else if (estatusLower == "adeudo") { badgeClass += "badge-adeudo"; }
                        else if (estatusLower == "inactivo") { badgeClass += "badge-inactivo"; }
                        else { badgeClass += "badge-nuevo"; }
                    }
                    <span class="@badgeClass">@p.Estatus</span>
                </td>
                <td>@(p.FechaRegistro==DateTime.MinValue? "": p.FechaRegistro.ToString("yyyy-MM-dd"))</td>
                <td>
                    <button class="btn-action btn-editar" data-id="@p.ProspectoId" title="Editar" style="border:none; cursor:pointer;">E</button>
                    <button class="btn-action btn-eliminar" data-id="@p.ProspectoId" title="Eliminar" style="border:none; cursor:pointer; background-color: var(--color-danger); color: white;">X</button>
                </td>
            </tr>
        }
    </tbody>
</table>
