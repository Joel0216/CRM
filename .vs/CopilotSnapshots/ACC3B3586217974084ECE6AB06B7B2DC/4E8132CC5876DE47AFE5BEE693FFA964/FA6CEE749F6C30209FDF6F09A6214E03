@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Prospectos";
}

<h2 class="page-title">Lista de Prospectos</h2>

<div class="prospect-table">
    <div class="prospect-table-header d-flex justify-content-end mb-3">
        <button id="btnNuevo" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalProspecto">
            <i class="bi bi-plus-lg"></i> Nuevo Prospecto
        </button>
    </div>

    <div id="tablaContainer">
        @Html.Action("TablaProspectos", "ProspectosView")
    </div>

    <!-- Modal -->
    <div class="modal fade" id="modalProspecto" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Prospecto</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body" id="modalBodyProspecto">
          </div>
        </div>
      </div>
    </div>
</div>

@section scripts {
    <script>
        function inicializarTabla(){
            $('#tablaProspectos').DataTable({
                destroy: true,
                responsive: true,
                language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
                dom: 'Bfrtip',
                buttons: ['excel', 'print'],
                pageLength: 10
            });
        }

        $(function(){
            inicializarTabla();

            // Nuevo
            $('#btnNuevo').on('click', function(){
                $('#modalBodyProspecto').load('@Url.Action("FormularioProspecto","ProspectosView")');
            });

            // DelegaciÃ³n para editar
            $(document).on('click', '.btn-editar', function(){
                var id = $(this).data('id');
                $('#modalBodyProspecto').load('@Url.Action("FormularioProspecto","ProspectosView")' + '?id=' + id);
                var modal = new bootstrap.Modal(document.getElementById('modalProspecto'));
                modal.show();
            });

            // DelegaciÃ³n para eliminar
            $(document).on('click', '.btn-eliminar', function(){
                var id = $(this).data('id');
                Swal.fire({
                    title: 'Â¿Eliminar?',
                    text: 'Esta acciÃ³n no se puede deshacer',
                    icon: 'warning',
                    showCancelButton: true
                }).then((result)=>{
                        if(result.isConfirmed){
                        var token = $('input[name="__RequestVerificationToken"]').val();
                        $.post('@Url.Action("EliminarProspecto","ProspectosView")', { id: id, __RequestVerificationToken: token })
                        .done(function(res){
                            if(res.success){
                                $('#tablaContainer').load('@Url.Action("TablaProspectos","ProspectosView")', function(){ inicializarTabla(); });
                                Swal.fire('Eliminado','El prospecto fue eliminado.','success');
                            } else {
                                Swal.fire('Error', res.mensaje, 'error');
                            }
                        })
                        .fail(function(){ Swal.fire('Error','Error del servidor','error'); });
                    }
                });
            });
        });
    </script>
}
