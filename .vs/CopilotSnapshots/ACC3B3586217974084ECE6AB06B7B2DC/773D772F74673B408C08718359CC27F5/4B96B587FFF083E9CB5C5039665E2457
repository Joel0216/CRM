@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Prospectos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between mb-3">
        <h3>Prospectos</h3>
        <button id="btnNuevo" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalProspecto">Nuevo Prospecto</button>
    </div>

    <div id="tablaContainer">
        @Html.Action("TablaProspectos", "ProspectosView")
    </div>

    <!-- Modal -->
    <div class="modal fade" id="modalProspecto" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Prospecto</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body" id="modalBodyProspecto">
          </div>
        </div>
      </div>
    </div>
</div>

@section scripts {
    <script>
        function inicializarTabla(){
            $('#tablaProspectos').DataTable({ destroy: true, responsive: true });
        }

        $(function(){
            inicializarTabla();

            // Nuevo
            $('#btnNuevo').on('click', function(){
                $('#modalBodyProspecto').load('@Url.Action("FormularioProspecto","ProspectosView")');
            });

            // Delegación para editar
            $(document).on('click', '.btn-editar', function(){
                var id = $(this).data('id');
                $('#modalBodyProspecto').load('@Url.Action("FormularioProspecto","ProspectosView")' + '?id=' + id);
                var modal = new bootstrap.Modal(document.getElementById('modalProspecto'));
                modal.show();
            });

            // Delegación para eliminar
            $(document).on('click', '.btn-eliminar', function(){
                var id = $(this).data('id');
                Swal.fire({
                    title: '¿Eliminar?',
                    text: 'Esta acción no se puede deshacer',
                    icon: 'warning',
                    showCancelButton: true
                }).then((result)=>{
                    if(result.isConfirmed){
                        $.post('@Url.Action("EliminarProspecto","ProspectosView")', { id: id })
                        .done(function(res){
                            if(res.success){
                                $('#tablaContainer').load('@Url.Action("TablaProspectos","ProspectosView")', function(){ inicializarTabla(); });
                                Swal.fire('Eliminado','El prospecto fue eliminado.','success');
                            } else {
                                Swal.fire('Error', res.mensaje, 'error');
                            }
                        })
                        .fail(function(){ Swal.fire('Error','Error del servidor','error'); });
                    }
                });
            });
        });
    </script>
}
