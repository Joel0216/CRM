@model CRMCiclo.Models.ProspectoModel

@using (Html.BeginForm(null, null, FormMethod.Post, new { id = "formProspecto" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.ProspectoId)

    <div class="mb-3">
        <label class="form-label">Nombre Completo</label>
        @Html.TextBoxFor(m => m.NombreCompleto, new { @class = "form-control", required = "required" })
    </div>
    <div class="mb-3">
        <label class="form-label">Empresa</label>
        @Html.TextBoxFor(m => m.Empresa, new { @class = "form-control" })
    </div>
    <div class="mb-3">
        <label class="form-label">TelÃ©fono</label>
        @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control" })
    </div>
    <div class="mb-3">
        <label class="form-label">Email</label>
        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email" })
    </div>
    <div class="mb-3">
        <label class="form-label">Origen</label>
        @Html.DropDownListFor(m => m.Origen, new SelectList(new[]{ "Referido","Web","Llamada" }), "Seleccione", new { @class = "form-control" })
    </div>
    <div class="mb-3">
        <label class="form-label">Estatus</label>
        @Html.DropDownListFor(m => m.Estatus, new SelectList(new[]{ "Nuevo","En seguimiento","Cerrado" }), "Seleccione", new { @class = "form-control" })
    </div>
    <div class="mb-3">
        <label class="form-label">Notas</label>
        @Html.TextAreaFor(m => m.Notas, 5, 50, new { @class = "form-control" })
    </div>

    <div class="d-flex justify-content-end">
        <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-primary">Guardar</button>
    </div>
}

@section scripts {
    <script>
        $(function(){
            $('#formProspecto').on('submit', function(e){
                e.preventDefault();
                var data = $(this).serialize();
                $.ajax({
                    url: '@Url.Action("GuardarProspecto","ProspectosView")',
                    method: 'POST',
                    data: data + '&' + encodeURIComponent($('input[name="__RequestVerificationToken"]').attr('name')) + '=' + encodeURIComponent($('input[name="__RequestVerificationToken"]').val()),
                    success: function(res){
                        if(res.success){
                            var modalEl = document.getElementById('modalProspecto');
                            var modal = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
                            modal.hide();
                            $('#tablaContainer').load('@Url.Action("TablaProspectos","ProspectosView")', function(){ $('#tablaProspectos').DataTable(); });
                            Swal.fire('Correcto', res.mensaje, 'success');
                        } else {
                            Swal.fire('Error', res.mensaje, 'error');
                        }
                    },
                    error: function(){ Swal.fire('Error','Error del servidor','error'); }
                });
            });
        });
    </script>
}
