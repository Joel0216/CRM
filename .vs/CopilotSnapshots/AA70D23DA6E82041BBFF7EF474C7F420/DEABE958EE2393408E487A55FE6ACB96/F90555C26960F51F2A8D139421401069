import React from 'react'
import { MapContainer, TileLayer, Marker, useMap } from 'react-leaflet'
import L from 'leaflet'
import { calcularCotizacion } from '../data'

const SERVICIOS_PRESET = [
  { nombre: 'Recolección RSU General', precio: 1800 },
  { nombre: 'Recolección RME (Manejo Especial)', precio: 2400 },
  { nombre: 'Disposición Final Certificada', precio: 600 },
  { nombre: 'Recolección de Reciclables', precio: 450 },
  { nombre: 'Retiro de Voluminosos', precio: 300 },
  { nombre: 'Gestión RAEE (Electrónicos)', precio: 1200 },
  { nombre: 'Limpieza de Contenedor 240L', precio: 180 },
  { nombre: 'Renta de Contenedor Industrial', precio: 950 },
]

const PERIOD_DISC = { Mensual: 0, Trimestral: 3, Semestral: 7, Anual: 12 }

function makePinIcon(adeudo) {
  let cls, emoji
  if (adeudo === 0) { cls = 'map-pin-green'; emoji = '✔' }
  else if (adeudo <= 3000) { cls = 'map-pin-amber'; emoji = '⚡' }
  else { cls = 'map-pin-red'; emoji = '🔥' }
  return L.divIcon({
    className: '',
    html: `<div class="map-pin-wrap ${cls}" title="Adeudo: $${adeudo}">${emoji}</div>`,
    iconSize: [40, 40],
    iconAnchor: [20, 20],
  })
}

function MapUpdater({ lat, lng }) {
  const map = useMap()
  React.useEffect(() => {
    if (lat && lng) map.setView([lat, lng], 15, { animate: true })
  }, [lat, lng])
  return null
}

function DragMarker({ lat, lng, adeudo, onDrag }) {
  const markerRef = React.useRef(null)
  const icon = makePinIcon(adeudo)

  const eventHandlers = React.useMemo(() => ({
    dragend() {
      const m = markerRef.current
      if (m) {
        const pos = m.getLatLng()
        onDrag(pos.lat, pos.lng)
      }
    }
  }), [onDrag])

  return (
    <Marker
      ref={markerRef}
      position={[lat, lng]}
      icon={icon}
      draggable
      eventHandlers={eventHandlers}
    />
  )
}


// ── MAIN QUOTE MODULE ─────────────────────────────────────────────────────────
export default function Quote({ activeProspect }) {
  const [lat, setLat] = React.useState(activeProspect?.lat || 20.9674)
  const [lng, setLng] = React.useState(activeProspect?.lng || -89.5926)
  const [items, setItems] = React.useState([])
  const [periodicidad, setPeriodicidad] = React.useState('Mensual')
  const [descuentoPct, setDescuentoPct] = React.useState(0)
  const [totals, setTotals] = React.useState(null)
  const [fechaInicio, setFechaInicio] = React.useState('')
  const [fechaFin, setFechaFin] = React.useState('')
  const [addServicio, setAddServicio] = React.useState('')
  const adeudo = activeProspect?.adeudo || 0

  // Sync coords when prospect changes
  React.useEffect(() => {
    if (activeProspect?.lat) { setLat(activeProspect.lat); setLng(activeProspect.lng) }
  }, [activeProspect])

  // Auto-recalculate
  React.useEffect(() => { if (items.length > 0) calculate() }, [items, periodicidad, descuentoPct])

  const calculate = () => {
    if (items.length === 0) return
    const result = calcularCotizacion(items, periodicidad, descuentoPct)
    setTotals(result)
  }


  const addItem = () => {
    const preset = SERVICIOS_PRESET.find(s => s.nombre === addServicio) || SERVICIOS_PRESET[0]
    setItems(prev => [...prev, { id: Date.now(), nombre: preset.nombre, precio: preset.precio, cantidad: 1 }])
    setAddServicio('')
  }

  const removeItem = (id) => setItems(prev => prev.filter(x => x.id !== id))
  const updateItem = (id, key, val) => setItems(prev => prev.map(x => x.id === id ? { ...x, [key]: val } : x))

  const fmt = (n) => n != null ? `$${Number(n).toLocaleString('es-MX', { minimumFractionDigits: 2 })}` : '—'

  return (
    <div style={{ display: 'flex', flexDirection: 'column', height: '100%' }}>
      {/* TOPBAR */}
      <div className="topbar">
        <div>
          <div className="topbar-module-label">MÓDULO 04</div>
          <div className="topbar-title">
            Cotizador Activo
            {activeProspect && (
              <span style={{ fontWeight: 400, fontSize: 12, color: 'var(--brown-40)', marginLeft: 10 }}>
                — {activeProspect.nombre}
              </span>
            )}
          </div>
        </div>
        <div className="topbar-divider" />
        {activeProspect ? (
          <div style={{ display: 'flex', gap: 8, alignItems: 'center', fontSize: 11, color: 'var(--brown-70)' }}>
            <span className="badge badge-gray">{activeProspect.tipo}</span>
            <span className="badge badge-gray">{activeProspect.periodicidad}</span>
            {adeudo > 0 && (
              <span className={`badge ${adeudo > 3000 ? 'badge-red' : 'badge-amber'}`}>
                Adeudo: {fmt(adeudo)}
              </span>
            )}
          </div>
        ) : (
          <span className="text-mono text-small text-muted">Sin prospecto seleccionado — ve al Padrón y usa el botón $</span>
        )}
      </div>

      <div className="page-content animate-in">
        <div style={{ display: 'grid', gridTemplateColumns: '1fr 360px', gap: 12 }}>
          {/* LEFT COLUMN */}
          <div style={{ display: 'flex', flexDirection: 'column', gap: 10 }}>

            {/* FECHAS */}
            <div className="card">
              <div className="card-header"><span className="card-title">Parámetros de la Cotización</span></div>
              <div className="card-body">
                <div className="form-grid form-grid-2">
                  <div className="field">
                    <label className="field-label">Fecha de Inicio</label>
                    <input className="input" type="date" value={fechaInicio} onChange={e => setFechaInicio(e.target.value)} id="quote-fecha-inicio" />
                  </div>
                  <div className="field">
                    <label className="field-label">Fecha de Vencimiento</label>
                    <input className="input" type="date" value={fechaFin} onChange={e => setFechaFin(e.target.value)} id="quote-fecha-fin" />
                  </div>
                </div>
              </div>
            </div>

            {/* MAPA */}
            <div className="card">
              <div className="card-header">
                <span className="card-title">Verificación de Domicilio</span>
                <span style={{ marginLeft: 'auto', fontSize: 9, fontFamily: 'JetBrains Mono, monospace', color: 'var(--brown-40)' }}>
                  {adeudo === 0 ? '✔ SIN ADEUDO' : adeudo <= 3000 ? '⚡ ADEUDO MENOR' : '🔥 ADEUDO MAYOR'}
                </span>
              </div>
              <div className="card-body" style={{ padding: '10px 12px' }}>
                <div style={{ borderRadius: 6, overflow: 'hidden', border: '1px solid var(--brown-08)' }}>
                  <MapContainer
                    center={[lat, lng]}
                    zoom={15}
                    style={{ height: 240, width: '100%' }}
                    id="quote-map"
                    zoomControl={true}
                  >
                    <TileLayer
                      attribution='&copy; <a href="https://carto.com/">CartoDB</a>'
                      url="https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png"
                    />
                    <MapUpdater lat={lat} lng={lng} />
                    <DragMarker
                      lat={lat} lng={lng} adeudo={adeudo}
                      onDrag={(la, ln) => { setLat(+la.toFixed(6)); setLng(+ln.toFixed(6)) }}
                    />
                  </MapContainer>
                </div>
                <div className="form-grid form-grid-2" style={{ marginTop: 10 }}>
                  <div className="field">
                    <label className="field-label">Latitud</label>
                    <input className="input" type="number" step="any" value={lat}
                      onChange={e => setLat(parseFloat(e.target.value))}
                      style={{ fontFamily: 'JetBrains Mono, monospace' }} id="quote-lat" />
                  </div>
                  <div className="field">
                    <label className="field-label">Longitud</label>
                    <input className="input" type="number" step="any" value={lng}
                      onChange={e => setLng(parseFloat(e.target.value))}
                      style={{ fontFamily: 'JetBrains Mono, monospace' }} id="quote-lng" />
                  </div>
                </div>
                {activeProspect?.direccion && (
                  <div style={{ marginTop: 8, fontSize: 11, color: 'var(--brown-70)', fontFamily: 'JetBrains Mono, monospace', padding: '5px 8px', background: 'var(--bg)', borderRadius: 4 }}>
                    📍 {activeProspect.direccion}
                  </div>
                )}
              </div>
            </div>

            {/* SERVICIOS */}
            <div className="card">
              <div className="card-header"><span className="card-title">Servicios a Cotizar</span></div>
              <div className="card-body">
                {/* ADD ROW */}
                <div style={{ display: 'flex', gap: 8, marginBottom: 10 }}>
                  <select className="input" value={addServicio} onChange={e => setAddServicio(e.target.value)} style={{ flex: 1 }} id="servicio-select">
                    <option value="">Seleccionar servicio predefinido...</option>
                    {SERVICIOS_PRESET.map(s => (
                      <option key={s.nombre} value={s.nombre}>{s.nombre} — ${s.precio.toLocaleString('es-MX')}/mes</option>
                    ))}
                  </select>
                  <button className="btn btn-primary" onClick={addItem} id="servicio-add">+ Agregar</button>
                </div>

                {items.length === 0 ? (
                  <div style={{ textAlign: 'center', padding: '20px 0', color: 'var(--brown-40)', fontSize: 11, fontFamily: 'JetBrains Mono, monospace' }}>
                    Agrega conceptos para iniciar la cotización
                  </div>
                ) : (
                  <table className="data-table" style={{ marginBottom: 10 }}>
                    <thead>
                      <tr>
                        <th>Concepto</th>
                        <th style={{ width: 110 }}>Precio/mes</th>
                        <th style={{ width: 80 }}>Cantidad</th>
                        <th style={{ width: 90, textAlign: 'right' }}>Subtotal</th>
                        <th style={{ width: 40 }}></th>
                      </tr>
                    </thead>
                    <tbody>
                      {items.map(it => (
                        <tr key={it.id}>
                          <td>
                            <input className="input" value={it.nombre}
                              onChange={e => updateItem(it.id, 'nombre', e.target.value)}
                              style={{ fontSize: 11, padding: '3px 6px' }} />
                          </td>
                          <td>
                            <input className="input" type="number" min="0" value={it.precio}
                              onChange={e => updateItem(it.id, 'precio', parseFloat(e.target.value) || 0)}
                              style={{ fontFamily: 'JetBrains Mono, monospace', fontSize: 11, padding: '3px 6px' }} />
                          </td>
                          <td>
                            <input className="input" type="number" min="1" value={it.cantidad}
                              onChange={e => updateItem(it.id, 'cantidad', parseInt(e.target.value) || 1)}
                              style={{ fontFamily: 'JetBrains Mono, monospace', fontSize: 11, padding: '3px 6px' }} />
                          </td>
                          <td style={{ textAlign: 'right', fontFamily: 'JetBrains Mono, monospace', fontSize: 11 }}>
                            {fmt(it.precio * it.cantidad)}
                          </td>
                          <td>
                            <button className="btn btn-danger btn-icon btn-sm" onClick={() => removeItem(it.id)}>✕</button>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                )}

                {/* PERIODICIDAD */}
                <div style={{ marginBottom: 12 }}>
                  <div className="field-label" style={{ marginBottom: 6 }}>Periodicidad de Pago</div>
                  <div className="period-tabs">
                    {['Mensual', 'Trimestral', 'Semestral', 'Anual'].map(p => (
                      <button key={p} className={`period-tab${periodicidad === p ? ' active' : ''}`}
                        onClick={() => setPeriodicidad(p)} id={`period-${p.toLowerCase()}`}>
                        {p}
                        {PERIOD_DISC[p] > 0 && (
                          <span style={{ fontSize: 8, opacity: 0.7, marginLeft: 3 }}>-{PERIOD_DISC[p]}%</span>
                        )}
                      </button>
                    ))}
                  </div>
                </div>

                {/* DESCUENTO */}
                <div className="field" style={{ maxWidth: 200, marginBottom: 12 }}>
                  <label className="field-label">Descuento Comercial (%)</label>
                  <input className="input" type="number" min="0" max="40" value={descuentoPct}
                    onChange={e => setDescuentoPct(parseFloat(e.target.value) || 0)}
                    style={{ fontFamily: 'JetBrains Mono, monospace' }} id="quote-descuento" />
                </div>

                {/* SPEI NOTICE */}
                <div className="alert-strip spei" style={{ marginBottom: 10 }}>
                  <span>🏦</span>
                  <span><strong>Pago exclusivo por transferencia bancaria SPEI</strong> — Mantiene trazabilidad y seguridad en todas las transacciones.</span>
                </div>

                {/* TOTAL BOX */}
                {totals && (
                  <div className="total-box">
                    {[
                      { label: `Subtotal (×${totals.factor} mes${totals.factor > 1 ? 'es' : ''})`, val: totals.subtotal },
                      { label: `Descuento (${totals.totalDisc}%)`, val: -totals.descuento },
                      { label: 'IVA 16%', val: totals.iva },
                    ].map(r => (
                      <div key={r.label} className="total-box-row">
                        <span className="total-box-label">{r.label}</span>
                        <span style={{ fontFamily: 'JetBrains Mono, monospace', fontSize: 12 }}>{fmt(Math.abs(r.val))}</span>
                      </div>
                    ))}
                    <div className="total-box-row main">
                      <span>TOTAL {periodicidad.toUpperCase()}</span>
                      <span>{fmt(totals.total)}</span>
                    </div>
                    {totals.factor > 1 && (
                      <div style={{ fontSize: 9, color: 'rgba(255,255,255,0.4)', textAlign: 'right', marginTop: 4, fontFamily: 'JetBrains Mono, monospace' }}>
                        Equivalente mensual: {fmt(totals.total / totals.factor)}
                      </div>
                    )}
                  </div>
                )}

                {items.length > 0 && !totals && (
                  <button className="btn btn-primary w-full" onClick={calculate} id="quote-calculate">
                    Calcular Total
                  </button>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  )
}
