@{
    ViewBag.Title      = "Prospectos";
    ViewBag.ActiveMenu = "Prospectos";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h5 class="mb-0 fw-bold">
        <i class="fas fa-users me-2" style="color:#9E652E"></i>
        Gestión de Prospectos
    </h5>
    <a href="@Url.Action("Formulario","Prospectos")"
       class="btn btn-sm"
       style="background:#9E652E;color:#fff;border:none;">
        <i class="fas fa-plus me-1"></i> Nuevo Prospecto
    </a>
</div>

<!-- Filtro de estatus -->
<div class="card mb-3 shadow-sm">
    <div class="card-body py-2">
        <div class="row align-items-center g-2">
            <div class="col-auto">
                <label class="form-label mb-0 fw-semibold">Filtrar por estatus:</label>
            </div>
            <div class="col-auto">
                <select id="filtroEstatus" class="form-select form-select-sm">
                    <option value="">Todos</option>
                    <option>Nuevo</option>
                    <option>Contactado</option>
                    <option>Calificado</option>
                    <option>Propuesta</option>
                    <option>Negociación</option>
                    <option>Ganado</option>
                    <option>Perdido</option>
                </select>
            </div>
            <div class="col-auto">
                <button id="btnFiltrar" class="btn btn-sm btn-outline-secondary">
                    <i class="fas fa-filter me-1"></i> Aplicar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Tabla de prospectos -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        <table id="tblProspectos" class="table table-hover table-striped mb-0 align-middle">
            <thead style="background:#9E652E;color:#fff;">
                <tr>
                    <th>#</th>
                    <th>Nombre Prospecto</th>
                    <th>Empresa</th>
                    <th>Correo</th>
                    <th>Teléfono</th>
                    <th>Estatus</th>
                    <th>Tipo Inmueble</th>
                    <th>Registro</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody id="tbodyProspectos">
                <tr>
                    <td colspan="9" class="text-center py-4 text-muted">
                        <span class="spinner-border spinner-border-sm me-2"></span>Cargando...
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@section scripts {
<script>
// ── Mapa de colores por estatus ──────────────────────────────────
const ESTATUS_BADGE = {
    'Nuevo':        'primary',
    'Contactado':   'info',
    'Calificado':   'secondary',
    'Propuesta':    'warning',
    'Negociación':  'dark',
    'Ganado':       'success',
    'Perdido':      'danger'
};

let dataTable = null;

// ── Cargar tabla de prospectos ───────────────────────────────────
function cargarProspectos(estatus) {
    const url = '/Prospectos/ObtenerLista' + (estatus ? '?estatus=' + estatus : '');

    if (dataTable) {
        dataTable.destroy();
        dataTable = null;
    }

    $.getJSON(url, function (resp) {
        const $tbody = $('#tbodyProspectos');
        $tbody.empty();

        if (!resp.success || !resp.data || resp.data.length === 0) {
            $tbody.html('<tr><td colspan="9" class="text-center text-muted py-4">Sin registros encontrados.</td></tr>');
            return;
        }

        resp.data.forEach(function (p) {
            const badge   = ESTATUS_BADGE[p.Estatus] || 'secondary';
            const fecha   = p.Fecha_Creacion ? new Date(p.Fecha_Creacion).toLocaleDateString('es-MX') : '—';
            const correo  = p.Correo   || '—';
            const telefono= p.Telefono || '—';
            const tipo    = p.Tipo_Inmueble || '—';

            $tbody.append(`
                <tr>
                    <td>${p.Prospecto_ID}</td>
                    <td class="fw-semibold">${p.Nombre_Prospecto}</td>
                    <td>${p.Nombre_Comercial_Empresa}</td>
                    <td><a href="mailto:${correo}">${correo}</a></td>
                    <td>${telefono}</td>
                    <td><span class="badge bg-${badge}">${p.Estatus}</span></td>
                    <td>${tipo}</td>
                    <td>${fecha}</td>
                    <td class="text-center">
                        <a href="/Prospectos/Formulario?id=${p.Prospecto_ID}"
                           class="btn btn-sm btn-outline-warning me-1" title="Editar">
                            <i class="fas fa-edit"></i>
                        </a>
                        <button class="btn btn-sm btn-outline-danger btnEliminar"
                                data-id="${p.Prospecto_ID}"
                                data-nombre="${p.Nombre_Prospecto}"
                                title="Eliminar">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </td>
                </tr>
            `);
        });

        // Inicializar DataTable
        dataTable = $('#tblProspectos').DataTable({
            language: {
                url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json'
            },
            order: [[7, 'desc']],
            pageLength: 15
        });
    })
    .fail(function () {
        Swal.fire({
            icon:  'error',
            title: 'Error',
            text:  'No se pudo cargar la lista de prospectos.'
        });
    });
}

$(document).ready(function () {

    // Carga inicial
    cargarProspectos('');

    // Botón filtrar
    $('#btnFiltrar').on('click', function () {
        cargarProspectos($('#filtroEstatus').val());
    });

    // Eliminar — delegación de evento (filas dinámicas)
    $(document).on('click', '.btnEliminar', function () {
        const id     = $(this).data('id');
        const nombre = $(this).data('nombre');

        Swal.fire({
            icon:              'warning',
            title:             '¿Eliminar prospecto?',
            html:              `<b>${nombre}</b> será eliminado permanentemente.`,
            showCancelButton:  true,
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText:  'Cancelar',
            confirmButtonColor:'#d33',
            cancelButtonColor: '#6c757d'
        }).then(function (result) {
            if (!result.isConfirmed) return;

            $.post('/Prospectos/Eliminar', {
                id: id,
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
            })
            .done(function (resp) {
                if (resp.success) {
                    Swal.fire({
                        icon:             'success',
                        title:            '¡Eliminado!',
                        text:             resp.message,
                        confirmButtonColor:'#9E652E'
                    }).then(() => cargarProspectos($('#filtroEstatus').val()));
                } else {
                    Swal.fire({ icon: 'error', title: 'Error', text: resp.message });
                }
            })
            .fail(function () {
                Swal.fire({ icon: 'error', title: 'Error', text: 'No se pudo eliminar.' });
            });
        });
    });
});
</script>
@Html.AntiForgeryToken()
}
